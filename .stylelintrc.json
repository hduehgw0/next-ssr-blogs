{
  "extends": ["stylelint-config-standard"],
  "rules": {
    "import-notation": "string",
    "color-function-notation": "modern",
    "alpha-value-notation": "percentage",
    "rule-empty-line-before": null,
    "hue-degree-notation": "number",
    "lightness-notation": "number",
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "tailwind",
          "apply",
          "variants",
          "responsive",
          "screen",
          "layer",
          "theme",
          "custom-variant",
          "plugin"
        ]
      }
    ]
  }
}
